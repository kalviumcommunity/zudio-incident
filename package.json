{
  "name": "zudio-backend",
  "version": "1.0.0",
  "description": "Zudio fashion e-commerce backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "psql $DATABASE_URL -f src/migrations/001_create_tables.sql",
    "seed": "psql $DATABASE_URL -f src/seeds/seed.sql",
    "generate:seed": "node scripts/generate_seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "keywords": ["ecommerce", "fashion", "zudio", "api"],
  "author": "Zudio Dev Team",
  "license": "ISC"
}
